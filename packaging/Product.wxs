<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="IMD Insane Music Downloader"
    Language="1046"
    Version="$(var.ProductVersion)"
    Manufacturer="IMD"
    UpgradeCode="2F8E8229-9801-4D01-91DF-775EF1B2E2A0">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perUser"
      InstallPrivileges="limited"
      Description="IMD Insane Music Downloader" />

    <MajorUpgrade DowngradeErrorMessage="Uma versao mais nova do IMD ja esta instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="IMD Insane Music Downloader" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLFOLDER" Name="IMD Insane Music Downloader" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="IMD Insane Music Downloader" />
      </Directory>
    </Directory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="5A72D45E-1E54-4FE5-9E58-45B1072E5199">
        <Shortcut
          Id="StartMenuShortcut"
          Name="IMD Insane Music Downloader"
          Description="Abrir painel local do IMD"
          Target="[INSTALLFOLDER]IMD.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\IMD\InsaneMusicDownloader"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Product>
</Wix>
